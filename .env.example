# Copia este archivo como .env si en el futuro agregas APIs externas.
# No subas .env al repositorio.

# ODDS_API_KEY=
# API_FOOTBALL_KEY=
# POLYMARKET_API_KEY=

# Google Sheets privado de quinielas de amigos.
# Alternativa local: configs/friends_sheet.local.json, ignorado por Git.
# QUINIELA_FRIENDS_SHEET_ID=
# QUINIELA_FRIENDS_SHEET_GID=
# QUINIELA_FRIENDS_SHEET_NAME=

# SHA-256 hex de la contraseña local para bloquear secciones privadas en builds locales.
# No protege datos si el HTML privado se publica; el build publico no embebe DATA.friends.
# QUINIELA_PRIVATE_ACCESS_HASH=
